{
    "name": "statamic-addon/column-builder",
    "description": "Column Builder fieldtype",
    "type": "statamic-addon",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "statamic/cms": "^6.0",
        "statamic-addon/color-scheme": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Vizuall\\ColumnBuilder\\": "src/"
        }
    },
    "extra": {
        "statamic": {
            "name": "Column Builder",
            "provider": "Vizuall\\ColumnBuilder\\AddonServiceProvider"
        },
        "laravel": {
            "providers": [
                "Vizuall\\ColumnBuilder\\AddonServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
